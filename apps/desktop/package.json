{
  "name": "@stonks-only/desktop",
  "private": true,
  "version": "0.0.3",
  "description": "Stock training desktop app built with Electron, Vue 3 and Vite.",
  "author": "Stonks Only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -p tsconfig.json && vite build && electron-builder -mw",
    "build:mac": "vue-tsc -p tsconfig.json && vite build && electron-builder -m",
    "build:win": "vue-tsc -p tsconfig.json && vite build && electron-builder -w",
    "preview": "vite preview",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@klinecharts/pro": "^0.1.1",
    "@stonks-only/shared": "workspace:*",
    "@vicons/ionicons5": "^0.13.0",
    "appwrite": "^23.0.0",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.8.3",
    "klinecharts": "10.0.0-beta1",
    "naive-ui": "^2.44.1",
    "node-appwrite": "^14.2.0",
    "vue": "^3.4.21",
    "vue-i18n": "9",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-vue": "^5.0.4",
    "autoprefixer": "^10.4.27",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "jsdom": "^24.1.3",
    "postcss": "^8.5.8",
    "prebuild-install": "^7.1.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^2.1.9",
    "vue-tsc": "^2.0.26"
  },
  "main": "dist-electron/main.js"
}
